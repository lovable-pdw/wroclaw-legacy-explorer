# PayU Configuration
# Set PAYU_SANDBOX=true to use sandbox environment, false or omit for production
PAYU_SANDBOX=true

# Your PayU Sandbox Credentials (get these from https://secure.snd.payu.com)
# If not provided, will use public sandbox credentials for testing
PAYU_CLIENT_ID=your_sandbox_client_id
PAYU_CLIENT_SECRET=your_sandbox_client_secret
PAYU_MERCHANT_POS_ID=your_sandbox_merchant_pos_id

# Production Credentials (only use when PAYU_SANDBOX=false)
# PAYU_CLIENT_ID=your_production_client_id
# PAYU_CLIENT_SECRET=your_production_client_secret
# PAYU_MERCHANT_POS_ID=your_production_merchant_pos_id

# Server Configuration
PORT=3001
NODE_ENV=development